{
  "name": "workspace",
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "22.x"
  },
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/dev-all.mjs",
    "build": "tsc --build && npx --yes pnpm@10.33.0 -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck && npx --yes pnpm@10.33.0 -r --if-present run build",
    "build:frontend": "npx --yes pnpm@10.33.0 --filter @workspace/campusmart run build",
    "build:api": "npx --yes pnpm@10.33.0 --filter @workspace/api-server run build",
    "start": "npx --yes pnpm@10.33.0 --filter @workspace/api-server run start",
    "typecheck:libs": "tsc --build",
    "typecheck": "tsc --build && npx --yes pnpm@10.33.0 -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "get-port": "^7.1.0",
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
